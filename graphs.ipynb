import numpy as np
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA


np.random.seed(42)
cov_matrix = [[3, 2, 1], [2, 3, 1], [1, 1, 0.5]]
data_3d = np.random.multivariate_normal([0, 0, 0], cov_matrix, 200)


pca = PCA(n_components=3)
pca.fit(data_3d)
data_pca = pca.transform(data_3d)


fig = plt.figure(figsize=(15, 5))


ax1 = fig.add_subplot(131, projection='3d')
ax1.scatter(data_3d[:, 0], data_3d[:, 1], data_3d[:, 2], alpha=0.3, color='blue')


mean_x, mean_y, mean_z = pca.mean_
for variance, vector in zip(pca.explained_variance_, pca.components_):
    v = -vector * np.sqrt(variance) * 2
    ax1.quiver(mean_x, mean_y, mean_z, v[0], v[1], v[2], 
               color='black', arrow_length_ratio=0.1, linewidth=2.5)

ax1.set_title('Original 3D Data + Components')
ax1.set_xlabel('X')
ax1.set_ylabel('Y')
#ax1.set_zlabel('Z')


ax2 = fig.add_subplot(132)

ax2.scatter(data_pca[:, 0], data_pca[:, 1], alpha=0.5, color='red')
ax2.set_title('2D Projection (PC1 & PC2)')
ax2.set_xlabel('Principal Component 1')
ax2.set_ylabel('Principal Component 2')
ax2.grid(True, linestyle='--', alpha=0.6)


ax3 = fig.add_subplot(133)
ax3.scatter(data_pca[:, 0], np.zeros_like(data_pca[:, 0]), alpha=0.5, color='green')
ax3.set_title('1D Projection (PC1 Only)')
ax3.set_xlabel('Principal Component 1')

ax3.get_yaxis().set_visible(False) 
ax3.spines['left'].set_visible(False)
ax3.spines['right'].set_visible(False)
ax3.spines['top'].set_visible(False)

plt.tight_layout()
plt.savefig('/Users/piotrkedzierski/Documents/LaTex/PCA/pca_full_transformation.png', dpi=600)
